# Supabase — from https://supabase.com/dashboard/project/_/settings/api
# Public — safe to ship to the browser, protected by Row Level Security
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — bypasses RLS, NEVER expose to client code
# Used in API routes for trusted operations only
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Blob (added in M3 when deploying)
# BLOB_READ_WRITE_TOKEN=
